{
    "name": "thelia/web-scheduler-module",
    "description": "Expose Symfony Console commands as HMAC-signed HTTP triggers, adaptive to the hosting capabilities (CLI fork, FastCGI finish, synchronous).",
    "license": "LGPL-3.0-or-later",
    "type": "thelia-module",
    "keywords": [
        "thelia",
        "thelia-module",
        "cron",
        "scheduler",
        "web-cron",
        "infomaniak",
        "shared-hosting"
    ],
    "authors": [
        {
            "name": "Alexandre Noziere",
            "email": "anoziere@openstudio.fr"
        }
    ],
    "require": {
        "php": "^8.3",
        "thelia/installer": "~1.1",
        "symfony/lock": "^6.4 || ^7.0",
        "symfony/process": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "WebScheduler\\": ""
        },
        "exclude-from-classmap": [
            "I18n/"
        ]
    },
    "extra": {
        "installer-name": "WebScheduler",
        "thelia": {
            "name": "WebScheduler",
            "version": "1.0.0"
        }
    }
}
